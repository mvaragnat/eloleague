<div class="games-container" data-controller="table-sort">
  <div class="page-header">
    <h1><%= t('players.title', username: @user.username) %></h1>
  </div>

  <div class="card">
    <div class="card-body">
      <%= form_with url: user_path(@user), method: :get, local: true do %>
        <label for="game_system_id" class="card-date" style="font-style:normal; font-weight:600;">
          <%= t('players.system') %>
        </label>
        <%= select_tag :game_system_id,
                       options_for_select(@stats_system_options, @selected_system_id),
                       include_blank: t('players.all_systems'),
                       onchange: 'this.form.submit()' %>
      <% end %>
    </div>
  </div>

  <% if @player_stats.any? %>
    <div class="card">
      <div class="card-header">
        <h3><%= t('players.stats_by_system') %></h3>
      </div>
      <div class="card-body">
        <% @player_stats.each do |system_stats| %>
          <div class="mb-6">
            <h4 class="text-lg font-semibold mb-2"><%= system_stats[:system_name] %></h4>

            <% elo = @elo_by_system[system_stats[:system_id]] %>
            <h5 class="text-sm font-medium text-gray-600 mb-1"><%= t('players.elo_label') %> <%= elo&.rating || EloRating::START_RATING %></h5>

            <%# Overall stats for this system %>
            <div class="mb-4">
              <h5 class="text-sm font-medium text-gray-600 mb-1"><%= t('players.stats_total') %></h5>
              <div class="overflow-x-auto">
                <table class="table w-full">
                  <thead>
                    <tr>
                      <th><%= t('stats.total_games') %></th>
                      <th><%= t('stats.wins') %></th>
                      <th><%= t('stats.losses') %></th>
                      <th><%= t('stats.draws') %></th>
                      <th><%= t('stats.win_percent') %></th>
                      <th><%= t('stats.loss_percent') %></th>
                      <th><%= t('stats.draw_percent') %></th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><%= system_stats[:total_games] %></td>
                      <td><%= system_stats[:wins] %></td>
                      <td><%= system_stats[:losses] %></td>
                      <td><%= system_stats[:draws] %></td>
                      <td><%= number_with_precision(system_stats[:win_percent], precision: 1) %>%</td>
                      <td><%= number_with_precision(system_stats[:loss_percent], precision: 1) %>%</td>
                      <td><%= number_with_precision(system_stats[:draw_percent], precision: 1) %>%</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <%# Per-faction stats %>
            <% if system_stats[:faction_rows].any? %>
              <div>
                <h5 class="text-sm font-medium text-gray-600 mb-1"><%= t('players.stats_by_faction') %></h5>
                <div class="overflow-x-auto">
                  <table class="table w-full">
                    <thead>
                      <tr>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="text"><%= t('stats.faction') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.total_games') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.wins') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.losses') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.draws') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.win_percent') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.loss_percent') %></th>
                        <th class="sortable" data-action="click->table-sort#sort" data-sort-type="number"><%= t('stats.draw_percent') %></th>
                      </tr>
                    </thead>
                    <tbody>
                      <% system_stats[:faction_rows].each do |row| %>
                        <tr>
                          <td><%= row[:faction_name] %></td>
                          <td><%= row[:total_games] %></td>
                          <td><%= row[:wins] %></td>
                          <td><%= row[:losses] %></td>
                          <td><%= row[:draws] %></td>
                          <td><%= number_with_precision(row[:win_percent], precision: 1) %>%</td>
                          <td><%= number_with_precision(row[:loss_percent], precision: 1) %>%</td>
                          <td><%= number_with_precision(row[:draw_percent], precision: 1) %>%</td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="card">
      <div class="card-body">
        <p class="card-date"><%= t('players.no_stats_for_system') %></p>
      </div>
    </div>
  <% end %>

  <div id="games-list">
    <% @events.each do |event| %>
      <%= render(GameEventComponent.new(event: event, current_user: @user)) %>
    <% end %>
    <% if @events.blank? %>
      <p class="card-date"><%= t('games.no_games') %></p>
    <% end %>
  </div>
</div>


