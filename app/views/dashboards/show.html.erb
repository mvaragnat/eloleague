<div>
  <div class="page-header">
    <h1><%= t('hello') %> <%= @user.username %></h1>
  </div>

  <div class="dashboard-layout">
    <div class="card dashboard-welcome-card">
      <div class="dashboard-welcome-card__header">
        <h2><%= t('dashboard.welcome_box.title') %></h2>
      </div>
      <div class="dashboard-welcome-card__body">
        <p><%= t('dashboard.welcome_box.paragraph_1') %></p>
        <p><%= t('dashboard.welcome_box.paragraph_2') %></p>
        <p><%= t('dashboard.welcome_box.paragraph_3') %></p>
        <p><%= t('dashboard.welcome_box.paragraph_4') %></p>
      </div>

      <div class="dashboard-actions-grid">
        <%= link_to new_game_event_path, class: "dashboard-action", data: { turbo_frame: "modal" } do %>
          <span class="dashboard-action__emoji">🎲</span>
          <span><%= t('dashboard.welcome_box.add_game') %></span>
        <% end %>
        <%= link_to user_path(@user), class: "dashboard-action" do %>
          <span class="dashboard-action__emoji">📊</span>
          <span><%= t('dashboard.welcome_box.view_my_stats') %></span>
        <% end %>
        <%= link_to tournaments_path, class: "dashboard-action dashboard-action--wide" do %>
          <span class="dashboard-action__emoji">🏆</span>
          <span><%= t('dashboard.welcome_box.join_or_organize_event') %></span>
        <% end %>
      </div>
    </div>

    <div class="games-container">
      <div id="games-list">
        <% if @games.any? %>
          <% @games.each do |game| %>
            <%= render GameEventComponent.new(event: game, current_user: @user) %>
          <% end %>
        <% else %>
          <div id="no-games-message" class="card">
            <p class="card-date"><%= t('games.no_games') %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= turbo_frame_tag "modal" %> 