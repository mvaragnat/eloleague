<div class="card">
  <div class="card-body">
    <% if standings.any? %>
      <% primary_key = tournament.primary_key %>
      <% tiebreak1_key = tournament.tiebreak1_key %>
      <% tiebreak2_key = tournament.tiebreak2_key %>
      <% highlight_keys = [primary_key, tiebreak1_key, tiebreak2_key].compact %>
      <% highlight_bg = 'background-color:#fff8c4;' %>

      <div style="overflow-x:auto;">
        <table class="ranking-table">
          <thead>
            <tr>
              <th class="ranking-th ranking-th--left">#</th>
              <th class="ranking-th ranking-th--left"><%= t('elo.player') %></th>
              <th class="ranking-th"><%= t('tournaments.show.standings.games_played', default: 'Games Played') %></th>
              <th class="ranking-th" style="<%= highlight_bg if highlight_keys.include?('points') %>"><%= t('tournaments.show.standings.points', default: 'Points') %></th>
              <th class="ranking-th" style="<%= highlight_bg if highlight_keys.include?('score_sum') %>"><%= t('tournaments.show.strategies.names.primary.score_sum', default: 'Score sum') %></th>
              <th class="ranking-th" style="<%= highlight_bg if highlight_keys.include?('sos') %>"><%= t('tournaments.show.strategies.names.primary.sos', default: 'Strength of Schedule') %></th>
              <% if highlight_keys.include?('secondary_score_sum') %>
                <th class="ranking-th" style="<%= highlight_bg %>"><%= t('tournaments.show.strategies.names.primary.secondary_score_sum', default: 'Secondary score sum') %></th>
              <% end %>
              <th class="ranking-th"><%= t('tournaments.show.standings.army_list', default: 'List') %></th>
            </tr>
          </thead>
          <tbody>
            <% standings.each_with_index do |row, idx| %>
              <tr>
                <td class="ranking-td ranking-td--rank"><%= idx + 1 %></td>
                <td class="ranking-td ranking-td--player">
                  <%= link_to row[:user].username, user_path(row[:user]) %>
                  <% if row[:registration]&.faction %>
                    <small class="ranking-faction"><em>(<%= row[:registration].faction.localized_name %>)</em></small>
                  <% end %>
                </td>
                <td class="ranking-td ranking-td--num"><%= tournament.matches.where(a_user: row[:user]).or(tournament.matches.where(b_user: row[:user])).where.not(result: 'pending').count %></td>
                <td class="ranking-td ranking-td--num" style="<%= highlight_bg if highlight_keys.include?('points') %>"><%= row[:points].to_f %></td>
                <td class="ranking-td ranking-td--num" style="<%= highlight_bg if highlight_keys.include?('score_sum') %>"><%= row[:score_sum].to_f %></td>
                <td class="ranking-td ranking-td--num" style="<%= highlight_bg if highlight_keys.include?('sos') %>"><%= row[:sos].to_f.round(2) %></td>
                <% if highlight_keys.include?('secondary_score_sum') %>
                  <td class="ranking-td ranking-td--num" style="<%= highlight_bg %>"><%= row[:secondary_score_sum].to_f %></td>
                <% end %>
                <td class="ranking-td" style="text-align:right;">
                  <% if row[:registration]&.army_list.present? %>
                    <%= link_to t('tournaments.show.standings.view_list', default: 'View'),
                        tournament_tournament_registration_path(tournament, row[:registration]),
                        data: { turbo_frame: "modal" },
                        class: "text-indigo-600 hover:text-indigo-900" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="card-date"><%= t('tournaments.show.no_standings', default: 'No results yet') %></p>
    <% end %>
  </div>
</div>
