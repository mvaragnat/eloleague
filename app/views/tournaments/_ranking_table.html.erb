<div class="card">
  <div class="card-body">
    <% if standings.any? %>
      <% primary_key = tournament.primary_key %>
      <% tiebreak1_key = tournament.tiebreak1_key %>
      <% tiebreak2_key = tournament.tiebreak2_key %>
      <% highlight_keys = [primary_key, tiebreak1_key, tiebreak2_key].compact %>

      <div class="overflow-x-auto">
        <table class="min-w-full text-xs sm:text-sm">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="text-left py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap">#</th>
              <th class="text-left py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap"><%= t('elo.player') %></th>
              <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap"><%= t('tournaments.show.standings.games_played', default: 'Games Played') %></th>

              <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap
                <%= 'bg-amber-50' if highlight_keys.include?('points') %>">
                <%= t('tournaments.show.standings.points', default: 'Points') %>
              </th>

              <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap
                <%= 'bg-amber-50' if highlight_keys.include?('score_sum') %>">
                <%= t('tournaments.show.strategies.names.primary.score_sum', default: 'Score sum') %>
              </th>

              <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap
                <%= 'bg-amber-50' if highlight_keys.include?('sos') %>">
                <%= t('tournaments.show.strategies.names.primary.sos', default: 'Strength of Schedule') %>
              </th>

              <% if highlight_keys.include?('secondary_score_sum') %>
                <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap bg-amber-50">
                  <%= t('tournaments.show.strategies.names.primary.secondary_score_sum', default: 'Secondary score sum') %>
                </th>
              <% end %>

              <th class="text-right py-2 px-1 sm:px-3 font-semibold text-gray-500 whitespace-nowrap"><%= t('tournaments.show.standings.army_list', default: 'List') %></th>
            </tr>
          </thead>
          <tbody>
            <% standings.each_with_index do |row, idx| %>
              <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                <td class="py-2 px-1 sm:px-3 text-gray-400 font-medium"><%= idx + 1 %></td>
                <td class="py-2 px-1 sm:px-3 whitespace-nowrap">
                  <%= link_to row[:user].username, user_path(row[:user]) %>
                  <% if row[:registration]&.faction %>
                    <br class="sm:hidden">
                    <small class="text-gray-400"><em>(<%= row[:registration].faction.localized_name %>)</em></small>
                  <% end %>
                </td>
                <td class="py-2 px-1 sm:px-3 text-right tabular-nums"><%= tournament.matches.where(a_user: row[:user]).or(tournament.matches.where(b_user: row[:user])).where.not(result: 'pending').count %></td>

                <td class="py-2 px-1 sm:px-3 text-right tabular-nums
                  <%= 'bg-amber-50' if highlight_keys.include?('points') %>">
                  <%= row[:points].to_f %>
                </td>

                <td class="py-2 px-1 sm:px-3 text-right tabular-nums
                  <%= 'bg-amber-50' if highlight_keys.include?('score_sum') %>">
                  <%= row[:score_sum].to_f %>
                </td>

                <td class="py-2 px-1 sm:px-3 text-right tabular-nums
                  <%= 'bg-amber-50' if highlight_keys.include?('sos') %>">
                  <%= row[:sos].to_f.round(2) %>
                </td>

                <% if highlight_keys.include?('secondary_score_sum') %>
                  <td class="py-2 px-1 sm:px-3 text-right tabular-nums bg-amber-50">
                    <%= row[:secondary_score_sum].to_f %>
                  </td>
                <% end %>

                <td class="py-2 px-1 sm:px-3 text-right">
                  <% if row[:registration]&.army_list.present? %>
                    <%= link_to t('tournaments.show.standings.view_list', default: 'View'),
                        tournament_tournament_registration_path(tournament, row[:registration]),
                        data: { turbo_frame: "modal" },
                        class: "text-indigo-600 hover:text-indigo-900" %>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="card-date"><%= t('tournaments.show.no_standings', default: 'No results yet') %></p>
    <% end %>
  </div>
</div>
