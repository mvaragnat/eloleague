<%= turbo_frame_tag "modal" do %>
	<div class="modal-overlay" data-controller="modal">
		<div class="modal-card" style="max-height:90vh; overflow-y:auto; width:90vw; max-width:800px;">
			<h2><%= t('tournaments.show.matches', default: 'Matches') %> — <%= @tournament.name %></h2>

      <% error_flags = game_event_error_flags(@game) %>
			<%= form_with(model: @game, url: tournament_tournament_matches_path(@tournament), scope: :game_event, data: { controller: "game-form form-errors", action: "submit->game-form#validate player-selected->game-form#onPlayerSelected player-removed->game-form#onPlayerRemoved", game_form_factions_url_value: game_factions_path(locale: I18n.locale), game_form_two_players_value: true, game_form_exactly_two_players_message_value: t('games.errors.exactly_two_players'), game_form_both_scores_required_message_value: t('games.errors.both_scores_required'), game_form_both_factions_required_message_value: t('games.errors.both_factions_required'), game_form_score_exceeds_max_message_value: t('games.errors.score_exceeds_max', max: '%{max}'), game_form_total_must_equal_message_value: t('games.errors.total_must_equal', total: '%{total}'), game_form_scoring_max_value: @tournament.scoring_system&.max_score_per_player, game_form_scoring_total_value: @tournament.scoring_system&.fix_total_score }) do |form| %>

				<!-- Hidden system select to trigger faction loading -->
				<select name="game_event[game_system_id]" style="display:none;">
					<option value="<%= @tournament.game_system_id %>" selected="selected"></option>
				</select>

        <div class="card" style="padding:0.75rem; margin-bottom:0.5rem;">
          <div class="card-date" style="font-style:normal; font-weight:600;">
            <%= t('tournaments.scoring.about', default: 'Scoring system') %>
          </div>
          <div>
            <% s = @tournament.scoring_system %>
            <% if s.present? %>
              <div><strong><%= s.name %></strong></div>
              <% if s.summary.present? %>
                <div class="card-date" style="font-style:normal;"><%= s.summary %></div>
              <% end %>
              <% if s.description.present? %>
                <div class="card" style="padding:0.5rem; margin-top:0.25rem;"><%= s.description.html_safe %></div>
              <% end %>
            <% end %>
          </div>
        </div>
				<div data-game-form-target="error" data-form-errors-target="summary" role="alert" class="form-error-summary" style="<%= @game&.errors&.any? ? '' : 'display:none;' %> color:#dc2626;font-size:0.875rem; margin-bottom:0.75rem;">
          <%= @game&.errors&.full_messages&.to_sentence %>
        </div>

				<% show_secondary = (@tournament.open? || @tournament.swiss?) && [@tournament.primary_key, @tournament.tiebreak1_key, @tournament.tiebreak2_key].include?('secondary_score_sum') %>
				<%= render partial: 'shared/participations_fields',
						 locals: { form: form,
									 preselected_user: @preselected_user,
									 preselected_removable: @preselected_removable,
									 tournament_id: @tournament.id,
									 show_secondary: show_secondary,
									 initial_factions: Game::Faction.where(game_system_id: @tournament.game_system_id).order(:name).to_a,
                   error_flags: error_flags } %>

				<div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:1rem;">
					<%= link_to t('layouts.shared.cancel'), "#", data: { action: "click->modal#close" }, class: "btn" %>
					<%= form.submit t('games.new.submit'), class: "btn btn-primary" %>
				</div>
			<% end %>
		</div>
	</div>
<% end %> 